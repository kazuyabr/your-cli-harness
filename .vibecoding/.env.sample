# ============================================
# Your CLI Harness — Environment Variables
# ============================================
# Copie este arquivo para .env e preencha as chaves
# cp .vibecoding/.env.sample .vibecoding/.env

# ============================================
# LLM PROVIDERS GRATUITOS (para testes)
# ============================================

# OpenRouter (free tier — suporta tool calls, streaming)
OPENROUTER_API_KEY=sk-or-xxxxx

# Groq (free tier — muito rápido, bom para testes)
GROQ_API_KEY=gsk_xxxxx

# Together AI (free tier — suporta tool calls)
TOGETHER_API_KEY=xxxxx

# LM Studio (local — sem custo, sem limites)
# Rode localmente e configure a porta
LM_STUDIO_URL=http://localhost:1234

# Ollama (local — sem custo, sem limites)
# Rode localmente: ollama serve
OLLAMA_URL=http://localhost:11434

# ============================================
# PROVIDERS PAGOS (opcional — para testes reais)
# ============================================

# Anthropic (Claude) — opcional
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI (GPT) — opcional
OPENAI_API_KEY=sk-xxxxx

# Google (Gemini) — opcional
GOOGLE_API_KEY=AIzaSyxxxxx

# xAI (Grok) — opcional
XAI_API_KEY=xai-xxxxx

# Azure OpenAI (opcional)
AZURE_OPENAI_API_KEY=xxxxx
AZURE_OPENAI_RESOURCE_NAME=xxxxx
AZURE_OPENAI_API_VERSION=2024-10-21

# ============================================
# VECTOR DATABASE (para testes de memória)
# ============================================

# Qdrant (opcional)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=xxxxx

# Pinecone (opcional)
PINECONE_API_KEY=xxxxx
PINECONE_ENVIRONMENT=us-east-1

# ============================================
# MCP SERVERS (para testes de integração)
# ============================================

# GitHub (opcional)
GITHUB_TOKEN=ghp_xxxxx

# Jira (opcional)
JIRA_URL=https://xxxxx.atlassian.net
JIRA_EMAIL=xxxxx
JIRA_API_TOKEN=xxxxx

# ============================================
# NPM (para testes de publicação)
# ============================================

# npm token (para publish via CI/CD)
NPM_TOKEN=npm_xxxxx

# ============================================
# CONFIGURAÇÕES DE TESTE
# ============================================

# Provider padrão para testes
# Opções: openrouter, groq, together, lmstudio, ollama, anthropic, openai
TEST_PROVIDER=openrouter

# Modelo padrão (depende do provider)
# OpenRouter: meta-llama/llama-3.1-8b-instruct:free
# Groq: llama-3.1-8b-instant
# Together: meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo
# LM Studio: carregado no app
# Ollama: llama3.2
TEST_MODEL=openrouter/owl-alpha

# Timeout de testes (ms)
TEST_TIMEOUT=30000

# Log level (debug, info, warn, error)
LOG_LEVEL=info
