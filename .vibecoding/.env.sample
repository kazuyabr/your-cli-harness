# ============================================
# Your CLI Harness — Environment Variables
# ============================================
# Copie este arquivo para .env e preencha as chaves
# cp .vibecoding/.env.sample .vibecoding/.env

# ============================================
# LLM PROVIDERS (para testes de API e E2E)
# ============================================

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI (GPT)
OPENAI_API_KEY=sk-xxxxx

# Google (Gemini)
GOOGLE_API_KEY=AIzaSyxxxxx

# xAI (Grok)
XAI_API_KEY=xai-xxxxx

# Azure OpenAI (opcional)
AZURE_OPENAI_API_KEY=xxxxx
AZURE_OPENAI_RESOURCE_NAME=xxxxx
AZURE_OPENAI_API_VERSION=2024-10-21

# ============================================
# VECTOR DATABASE (para testes de memória)
# ============================================

# Qdrant (opcional)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=xxxxx

# Pinecone (opcional)
PINECONE_API_KEY=xxxxx
PINECONE_ENVIRONMENT=us-east-1

# ============================================
# MCP SERVERS (para testes de integração)
# ============================================

# GitHub (opcional)
GITHUB_TOKEN=ghp_xxxxx

# Jira (opcional)
JIRA_URL=https://xxxxx.atlassian.net
JIRA_EMAIL=xxxxx
JIRA_API_TOKEN=xxxxx

# ============================================
# NPM (para testes de publicação)
# ============================================

# npm token (para publish via CI/CD)
NPM_TOKEN=npm_xxxxx

# ============================================
# CONFIGURAÇÕES DE TESTE
# ============================================

# Modelo padrão para testes
TEST_MODEL=claude-sonnet-4-20250514

# Provider padrão para testes
TEST_PROVIDER=anthropic

# Timeout de testes (ms)
TEST_TIMEOUT=30000

# Log level (debug, info, warn, error)
LOG_LEVEL=info
